{
  "expo": {
    "name": "Springs",
    "slug": "springs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "platforms":["ios", "android", "web"],
    "plugins": ["expo-camera"],
    "android": {
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#020617"
      }
    },
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos da câmera para ler o QR Code"
      }
    },
    "web": {
      "bundler": "metro",
      "name": "Palm Springs - Loyalty",
      "shortName": "Springs",
      "themeColor": "#facc15",
      "backgroundColor": "#020617",
      "display": "standalone",
      "favicon": "./assets/images/icon.png"
    }
  }
}